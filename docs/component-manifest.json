{
  "version": 2,
  "release": "v0.6.0-beta.0",
  "prefix": "dv-",
  "contract": {
    "configuration": "data-* attributes",
    "communication": "bubbling dv:* CustomEvents",
    "dom": "Light DOM",
    "runtime": "build-free native ES modules",
    "styling": "CKCSS or consumer global CSS"
  },
  "authoring": {
    "status": "experimental",
    "entry": "src/core/authoring.js",
    "distribution": "dist/authoring.min.js",
    "extension": ".dv.js",
    "componentShape": ["props", "state", "sync", "actions", "view"],
    "directives": ["on:*", "data-on:*"]
  },
  "components": [
    { "tag": "dv-counter", "class": "DvCounter", "authoring": "component()", "module": "src/components/dv-counter.js", "attributes": ["data-start", "data-step"], "events": ["dv:change"] },
    { "tag": "dv-tabs", "class": "DvTabs", "module": "src/components/dv-tabs.js", "attributes": ["data-active", "data-label"], "events": ["dv:tab"] },
    { "tag": "dv-disclosure", "class": "DvDisclosure", "module": "src/components/dv-disclosure.js", "attributes": ["data-open", "data-summary"], "events": ["dv:toggle"] },
    { "tag": "dv-modal", "class": "DvModal", "module": "src/components/dv-modal.js", "attributes": ["data-open", "data-label", "data-close"], "events": ["dv:open", "dv:close"] },
    { "tag": "dv-toast", "class": "DvToast", "module": "src/components/dv-toast.js", "attributes": ["data-message", "data-open", "data-duration"], "events": ["dv:show", "dv:hide"] },
    { "tag": "dv-pagination", "class": "DvPagination", "module": "src/components/dv-pagination.js", "attributes": ["data-page", "data-total", "data-size", "data-label", "data-jump-label", "data-previous-label", "data-next-label", "data-previous-page-label", "data-next-page-label", "data-page-label", "data-jump-aria-label", "data-go-label"], "events": ["dv:page"] },
    { "tag": "dv-dropdown", "class": "DvDropdown", "module": "src/components/dv-dropdown.js", "attributes": ["data-open", "data-label"], "events": ["dv:toggle"] },
    { "tag": "dv-search", "class": "DvSearch", "authoring": "component()", "module": "src/components/dv-search.js", "attributes": ["data-query", "data-label", "data-placeholder"], "events": ["dv:query"] },
    { "tag": "dv-product-card", "class": "DvProductCard", "module": "src/components/dv-product-card.js", "attributes": ["data-id", "data-name", "data-price", "data-action"], "events": ["dv:add-to-cart"] },
    { "tag": "dv-field", "class": "DvField", "module": "src/components/dv-field.js", "attributes": ["data-id", "data-name", "data-label", "data-control", "data-type", "data-options", "data-value", "data-placeholder", "data-required", "data-disabled", "data-error"], "events": ["dv:input", "dv:change"] },
    { "tag": "dv-confirm", "class": "DvConfirm", "module": "src/components/dv-confirm.js", "attributes": ["data-label", "data-message", "data-confirm-label", "data-cancel-label", "data-value", "data-confirming-label"], "events": ["dv:confirm", "dv:cancel"] },
    { "tag": "dv-autocomplete", "class": "DvAutocomplete", "module": "src/components/dv-autocomplete.js", "attributes": ["data-items", "data-query", "data-label"], "events": ["dv:query", "dv:select"] },
    { "tag": "dv-data-table", "class": "DvDataTable", "module": "src/components/dv-data-table.js", "attributes": ["data-columns", "data-rows", "data-page-size", "data-label", "data-filter-label", "data-pagination-label"], "events": ["dv:sort", "dv:filter"] },
    { "tag": "dv-cart", "class": "DvCart", "module": "src/components/dv-cart.js", "attributes": ["data-items", "data-label", "data-empty", "data-remove-label", "data-total-label", "data-decrease-label", "data-increase-label", "data-quantity-label"], "events": ["dv:change", "dv:remove"] },
    { "tag": "dv-toast-stack", "class": "DvToastStack", "module": "src/components/dv-toast-stack.js", "attributes": ["data-duration", "data-label", "data-dismiss"], "events": ["dv:show", "dv:hide"] },
    { "tag": "dv-state", "class": "DvState", "module": "src/components/dv-state.js", "attributes": ["data-state", "data-loading", "data-empty", "data-error", "data-retry-label"], "events": ["dv:retry"] }
  ]
}
