{
  "name": "devinimjs",
  "version": "0.6.0-beta.0",
  "description": "AI-first, build-free UI runtime: Svelte-like component authoring for PHP and shared hosting. The JS companion of CKCSS.",
  "type": "module",
  "keywords": [
    "web-components",
    "custom-elements",
    "proxy",
    "reactivity",
    "no-build",
    "php",
    "shared-hosting",
    "ckcss"
  ],
  "author": "Cüneyt Kaya (https://kayacuneyt.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kayacuneyd/devinimjs.git"
  },
  "types": "./types/core/core.d.ts",
  "exports": {
    ".": {
      "types": "./types/core/core.d.ts",
      "default": "./src/core/core.js"
    },
    "./authoring": {
      "types": "./types/core/authoring.d.ts",
      "default": "./src/core/authoring.js"
    },
    "./app": {
      "types": "./types/core/app.d.ts",
      "default": "./src/core/app.js"
    },
    "./components/*": {
      "types": "./types/components/*.d.ts",
      "default": "./src/components/*"
    }
  },
  "files": [
    "src",
    "dist",
    "docs",
    "adr",
    "scripts",
    "templates",
    "types"
  ],
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "build": "npm run build:types && node scripts/build-dist.mjs",
    "build:types": "node scripts/build-types.mjs",
    "validate:component": "node scripts/validate-component.mjs",
    "size": "node scripts/size-check.mjs",
    "serve": "node scripts/serve.mjs",
    "create:component": "node scripts/create-component.mjs",
    "verify": "npm run lint && npm test && npm run test:e2e && npm run size"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.30.0",
    "eslint-plugin-jsdoc": "^51.0.0",
    "happy-dom": "^17.4.0",
    "typescript": "^5.9.3"
  }
}
