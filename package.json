{
  "name": "devinimjs",
  "version": "0.4.0",
  "description": "Build-free, Proxy-reactive Vanilla JS component library for PHP and shared-hosting projects. The JS companion of CKCSS.",
  "type": "module",
  "keywords": [
    "web-components",
    "custom-elements",
    "proxy",
    "reactivity",
    "no-build",
    "php",
    "shared-hosting",
    "ckcss"
  ],
  "author": "Cüneyt Kaya (https://kayacuneyt.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kayacuneyd/devinimjs.git"
  },
  "exports": {
    ".": "./src/core/core.js",
    "./app": "./src/core/app.js",
    "./components/*": "./src/components/*"
  },
  "files": [
    "src",
    "dist",
    "docs",
    "adr",
    "templates"
  ],
  "scripts": {
    "test": "node --test \"tests/unit/*.test.js\"",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "build": "node scripts/build-dist.mjs",
    "size": "node scripts/size-check.mjs",
    "serve": "node scripts/serve.mjs",
    "create:component": "node scripts/create-component.mjs",
    "verify": "npm run lint && npm test && npm run test:e2e && npm run size"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.30.0",
    "eslint-plugin-jsdoc": "^51.0.0",
    "happy-dom": "^17.4.0"
  }
}
